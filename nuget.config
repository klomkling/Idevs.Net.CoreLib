<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!--
    Single-source configuration: all packages (including Serenity.*) come from
    nuget.org. The serenity.is private feed was previously listed but has been
    intermittently unavailable; nuget.org carries the same Serenity packages.
    Re-add a private feed here only if a package isn't published to nuget.org.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
