<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <!--
      Idevs.Net.CoreLib opt-in client assets installation.

      Behavior
      - On the first build that does not yet have @idevs/corelib in node_modules, this
        target shells out to npm install @idevs/corelib with the no-save option so consumer projects
        get the matching client-side assets.
      - On every build, any CSS shipped under @idevs/corelib/css is copied into
        wwwroot/lib/Idevs/Content for static serving.

      Opting out
      - Set <IdevsCoreLibInstallNpmPackage>false</IdevsCoreLibInstallNpmPackage> in the
        consuming project's csproj or via dotnet build /p:IdevsCoreLibInstallNpmPackage=false.
      - Useful for air-gapped CI or environments without npm.

      Failure modes handled here
      - Forward-slash paths so Exists() works on macOS/Linux as well as Windows.
      - If npm is not on PATH, the install step is skipped with a warning instead of
        producing an opaque exit-code build failure.
    -->

    <PropertyGroup>
        <IdevsCoreLibInstallNpmPackage Condition="'$(IdevsCoreLibInstallNpmPackage)' == ''">true</IdevsCoreLibInstallNpmPackage>
        <_IdevsCoreLibPackageMarker>$(ProjectDir)node_modules/@idevs/corelib/dist/index.d.ts</_IdevsCoreLibPackageMarker>
    </PropertyGroup>

    <Target Name="_IdevsCoreLibDetectNpm"
            Condition="'$(IdevsCoreLibInstallNpmPackage)' == 'true' And !Exists('$(_IdevsCoreLibPackageMarker)')">
        <Exec Command="npm --version"
              IgnoreExitCode="true"
              StandardOutputImportance="low"
              StandardErrorImportance="low"
              ConsoleToMSBuild="true">
            <Output TaskParameter="ExitCode" PropertyName="_IdevsCoreLibNpmExitCode" />
        </Exec>
        <PropertyGroup>
            <_IdevsCoreLibNpmAvailable Condition="'$(_IdevsCoreLibNpmExitCode)' == '0'">true</_IdevsCoreLibNpmAvailable>
            <_IdevsCoreLibNpmAvailable Condition="'$(_IdevsCoreLibNpmExitCode)' != '0'">false</_IdevsCoreLibNpmAvailable>
        </PropertyGroup>
        <Warning Condition="'$(_IdevsCoreLibNpmAvailable)' != 'true'"
                 Code="IDEVSCORELIB001"
                 Text="Skipping @idevs/corelib npm install: npm was not found on PATH. Set IdevsCoreLibInstallNpmPackage=false to silence this warning, or install Node.js to fetch client assets." />
    </Target>

    <Target Name="NpmInstall"
            BeforeTargets="BeforeBuild"
            DependsOnTargets="_IdevsCoreLibDetectNpm"
            Condition="'$(IdevsCoreLibInstallNpmPackage)' == 'true' And '$(_IdevsCoreLibNpmAvailable)' == 'true' And !Exists('$(_IdevsCoreLibPackageMarker)')">
        <Message Text="Installing @idevs/corelib via npm (set IdevsCoreLibInstallNpmPackage=false to opt out)..." Importance="high" />
        <!--
          Pin to the major matching this Idevs.Net.CoreLib version.
          0.7.x / 0.8.x / 0.9.x → @idevs/corelib 1.x (Serenity 8.8.9 lane, net8).
          When this package bumps to 1.0.0 (Serenity 10 / net10 lane), update
          the range to ">=2.0.0 <3.0.0".
          See: https://github.com/klomkling/idevs.corelib/blob/main/MIGRATION.md
        -->
        <Exec Command="npm install &quot;@idevs/corelib@&gt;=1.0.0 &lt;2.0.0&quot; --no-save"
              WorkingDirectory="$(ProjectDir)" />
    </Target>

    <Target Name="CopyContentToProject"
            BeforeTargets="Build"
            Condition="Exists('$(ProjectDir)node_modules/@idevs/corelib/css')">
        <ItemGroup>
            <ContentFiles Include="$(ProjectDir)node_modules/@idevs/corelib/css/*.css" />
        </ItemGroup>
        <Message Text="Copying @idevs/corelib content to wwwroot (changed files only)" Importance="normal" />
        <!--
          SkipUnchangedFiles compares source/destination size + timestamp per file
          and skips copies that are already current. Cheaper and more granular
          than wiring MSBuild Inputs/Outputs against a target-body ItemGroup
          (which evaluates to empty at skip-check time and never triggers an
          incremental skip).
        -->
        <Copy SourceFiles="@(ContentFiles)"
              DestinationFolder="$(ProjectDir)wwwroot/lib/Idevs/Content/"
              SkipUnchangedFiles="true" />
    </Target>
</Project>
